LET db = DB::SQLITE::OPEN({ memory: true })

LET create = QUERY ONE `CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT NOT NULL)` IN db USING sql_exec
LET firstInsert = QUERY ONE `INSERT INTO users(name) VALUES (?)` IN db USING sql_exec WITH { params: ["Ada"] }
LET secondInsert = QUERY ONE `INSERT INTO users(name) VALUES (?)` IN db USING sql_exec WITH { params: ["Grace"] }

LET first = QUERY ONE `
  SELECT id, name
  FROM users
  ORDER BY id
` IN db USING sql

LET count = QUERY COUNT `
  SELECT id
  FROM users
` IN db USING sql

LET exists = QUERY EXISTS `
  SELECT id
  FROM users
  WHERE name = ?
` IN db USING sql WITH { params: ["Grace"] }

T::EQ(first.name, "Ada")
T::EQ(count, 2)
T::TRUE(exists)

RETURN NONE
