LET db = DB::SQLITE::OPEN({ memory: true })

LET create = QUERY ONE `CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT NOT NULL)` IN db USING sql_exec

LET committed = DB::SQLITE::BEGIN(db)
LET committedInsert = QUERY ONE `INSERT INTO users(name) VALUES (?)` IN committed USING sql_exec WITH { params: ["Ada"] }
DB::SQLITE::COMMIT(committed)

LET rolledBack = DB::SQLITE::BEGIN(db)
LET rolledBackInsert = QUERY ONE `INSERT INTO users(name) VALUES (?)` IN rolledBack USING sql_exec WITH { params: ["Grace"] }
DB::SQLITE::ROLLBACK(rolledBack)

LET rows = QUERY `
  SELECT name
  FROM users
  ORDER BY id
` IN db USING sql

RETURN T::EQ(rows, [{ name: "Ada" }])
