LET api = NET::REST::CLIENT({
  baseUrl: @lab.mock.api,
  encoding: "json"
})

LET response = QUERY ONE "/health" IN api OPTIONS {
  response: "full"
}

T::TRUE(response.ok)
T::EQ(response.status, 200)
T::EQ(response.body.version, "1.0.0")
T::EQ(response.body.status, "ok")
T::EQ(response.url, @lab.mock.api + "/health")

RETURN NONE
