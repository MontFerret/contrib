LET api = NET::REST::CLIENT({
  baseUrl: @lab.mock.api,
  encoding: "json"
})

LET users = QUERY "/users" IN api
LET first = QUERY ONE "/users" IN api
LET count = QUERY COUNT "/users" IN api
LET exists = QUERY EXISTS "/users" IN api

T::EQ(users, [
  { id: 1, name: "User 1", active: true },
  { id: 2, name: "User 2", active: false },
  { id: 3, name: "User 3", active: true },
  { id: 4, name: "User 4", active: false },
  { id: 5, name: "User 5", active: true },
])
T::EQ(first.name, "User 1")
T::EQ(count, 5)
T::TRUE(exists)

RETURN NONE
