LET workbook = DOCUMENT::XLSX::CREATE()
LET sheet = DOCUMENT::XLSX::SHEET(workbook, "Sheet1")

DOCUMENT::XLSX::WRITE_RANGE(sheet, "A1:C4", [
  ["Name", "Active", "Score"],
  ["Alice", true, 92],
  ["Bob", false, 81],
  [NONE, NONE, NONE]
])

LET rows = QUERY "A1:C4" IN sheet WITH {
  headers: true,
  trimEmptyRows: true
}
LET shortcut = sheet[~ "A2:C3"]
LET first = QUERY ONE "A2:C3" IN sheet
LET count = QUERY COUNT "A2:C3" IN sheet
LET exists = QUERY EXISTS "A2:C3" IN sheet

T::EQ(rows[0].Name, "Alice")
T::EQ(rows[0].Active, true)
T::EQ(rows[0].Score, 92)
T::EQ(shortcut[1][0], "Bob")
T::EQ(first[0], "Alice")
T::EQ(count, 2)
T::TRUE(exists)

RETURN DOCUMENT::XLSX::CLOSE(workbook)
