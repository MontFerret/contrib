LET url = @lab.static.dynamic + "/#/events"
LET page = DOCUMENT(url, { driver: "cdp" })

INPUT(page, "#ajax-input", "index.html")
CLICK(page, "#ajax-input-button")

LET evt = WAITFOR EVENT "network.request_started" IN page
    WHEN CONTAINS(.url, "index.html")
    AND .method == "GET"
    AND .type == "fetch"
    TIMEOUT 10s

T::TRUE(CONTAINS(evt.url, "index.html"))

RETURN T::EQ({
    event: evt.event,
    method: evt.method,
    type: evt.type,
    failed: evt.failed
}, {
    event: "network.request_started",
    method: "GET",
    type: "fetch",
    failed: false
})
