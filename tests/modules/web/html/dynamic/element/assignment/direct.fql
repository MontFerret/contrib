LET url = @lab.static.dynamic + "?redirect=/forms"
LET doc = DOCUMENT(url, { driver: "cdp" })

WAIT_ELEMENT(doc, "form")

LET output = ELEMENT(doc, "#text_output")
output.textContent = "Continue"
T::EQ(output.textContent, "Continue")

output.innerText = "Go"
T::EQ(output.innerText, "Go")

output.innerHTML = "<strong>Submit</strong>"
T::EQ(output.innerHTML, "<strong>Submit</strong>")

LET input = ELEMENT(doc, "#text_input")
input.value = "hello@example.com"
T::EQ(input.value, "hello@example.com")

input.attributes = { placeholder: "Email" }
T::EQ(input.attributes.placeholder, "Email")

input.style = { display: "none" }
T::EQ(input.style.display, "none")

input.classes = ["assigned", "active"]
T::TRUE(input.classes.assigned)
T::TRUE(input.classes.active)

input.dataset = { productId: "123" }
T::EQ(input.dataset.productId, "123")
T::EQ(input.attributes["data-product-id"], "123")

input.disabled = TRUE
T::TRUE(input.disabled)

input.disabled = FALSE
T::FALSE(input.disabled)

LET checkbox = ELEMENT(doc, "#checkbox_input")
checkbox.checked = TRUE
T::TRUE(checkbox.checked)

checkbox.checked = FALSE
T::FALSE(checkbox.checked)

LET option = ELEMENT(doc, "#select_input option:nth-child(4)")
option.selected = TRUE
T::TRUE(option.selected)

RETURN NONE
