LET url = @lab.static.dynamic + "?redirect=/forms"
LET doc = DOCUMENT(url, { driver: "cdp" })

WAIT_ELEMENT(doc, "form")

LET el = ELEMENT(doc, "#text_input")
LET prevAttrs = el.attributes

el.attributes["aria-label"] = "Email"
T::NONE(prevAttrs["aria-label"])
T::EQ(el.attributes["aria-label"], "Email")

LET attrs = el.attributes
attrs.placeholder = "Email"
T::EQ(attrs.placeholder, "Email")
T::EQ(el.attributes.placeholder, "Email")

attrs.placeholder = NONE
T::NONE(attrs.placeholder)
T::NONE(el.attributes.placeholder)

LET style = el.style
style.display = "none"
T::EQ(style.display, "none")
T::EQ(el.style.display, "none")

style.backgroundColor = "rgb(255, 0, 0)"
T::EQ(style["background-color"], "rgb(255, 0, 0)")
T::EQ(el.style.backgroundColor, "rgb(255, 0, 0)")

style.display = NONE
T::NONE(style.display)

LET classes = el.classes
classes.active = TRUE
T::TRUE(classes.active)
T::TRUE(el.classes.active)

classes.active = FALSE
T::NONE(classes.active)
T::NONE(el.classes.active)

LET dataset = el.dataset
dataset.productId = "123"
T::EQ(dataset.productId, "123")
T::EQ(el.dataset.productId, "123")
T::EQ(el.attributes["data-product-id"], "123")

dataset["data-product-id"] = "456"
T::EQ(dataset.productId, "456")
T::EQ(el.dataset.productId, "456")
T::EQ(el.attributes["data-product-id"], "456")

dataset["data-foo_bar"] = "stable"
T::EQ(dataset.foo_bar, "stable")
T::EQ(el.dataset.foo_bar, "stable")
T::EQ(el.attributes["data-foo_bar"], "stable")
T::NONE(dataset.fooBar)

dataset["data-product-id"] = NONE
T::NONE(dataset.productId)
T::NONE(el.dataset.productId)
T::NONE(el.attributes["data-product-id"])

RETURN NONE
