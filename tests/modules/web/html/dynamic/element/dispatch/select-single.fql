LET url = @lab.static.dynamic + "?redirect=/forms"
LET doc = WEB::HTML::OPEN(url, { driver: "cdp" })

WAIT_ELEMENT(doc, "form")

LET input = ELEMENT(doc, "#select_input")
LET output = ELEMENT(doc, "#select_output")

DISPATCH "select" IN input WITH { value: "4" }

LET result = input.value

T::EQ(output.innerText, "4")
T::EQ(result, "4")

RETURN NONE