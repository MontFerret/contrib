LET url = @lab.static.static + "/article.html"
LET doc = DOCUMENT(url)
LET element = ELEMENT(doc, "article")
LET article = WEB::ARTICLE::EXTRACT(element)

T::EQ(article.title, "Ferret Lab Article Fixture")
T::NONE(article.canonicalUrl)
T::NONE(article.siteName)
T::NOT::NONE(article.text)
T::NOT::NONE(article.html)
T::NOT::NONE(article.markdown)
T::NOT::EQ(REGEX_REPLACE(article.text, "article extraction through the same runtime path", ""), article.text)
T::EQ(REGEX_REPLACE(article.text, "Overview Grid", ""), article.text)

RETURN NONE
